{
  "manifest_version": 3,
  "name": "Job Search Assistant",
  "version": "1.0",
  "description": "AI-powered freelance deal flow assistant",
  "permissions": ["activeTab", "sidePanel", "storage", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://bedrock-runtime.eu-central-1.amazonaws.com/*",
    "https://api.notion.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Analyze page"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open side panel and analyze page"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
